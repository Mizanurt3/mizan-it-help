-- Enum: Status
CREATE TYPE "Status" AS ENUM ('PENDING', 'ACTIVE', 'BLOCKED');

-- Table: users
CREATE TABLE "users" (
    "mobileNumber" TEXT PRIMARY KEY,
    "status" "Status" NOT NULL DEFAULT 'PENDING',
    "createdAt" TIMESTAMP NOT NULL DEFAULT NOW(),
    "lastLoginAt" TIMESTAMP,
    "notes" TEXT
);

-- Table: device_bindings
CREATE TABLE "device_bindings" (
    "id" TEXT PRIMARY KEY,
    "deviceId" TEXT UNIQUE NOT NULL,
    "boundAt" TIMESTAMP NOT NULL DEFAULT NOW(),
    "userMobile" TEXT UNIQUE NOT NULL,

    CONSTRAINT "device_bindings_user_fkey"
        FOREIGN KEY ("userMobile") REFERENCES "users"("mobileNumber")
        ON DELETE CASCADE
);

